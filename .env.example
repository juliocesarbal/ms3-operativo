# ===== MS3 Operativo - variables de entorno =====
# Copia este archivo a .env y ajusta los valores. El .env esta en .gitignore.

PORT=8000

# Base de datos del MS3 (database-per-service: INDEPENDIENTE de MS1 y MS2).
# Local sin setup: SQLite. Para tu Postgres propio, usa:
#   DATABASE_URL=postgresql+psycopg://usuario:clave@host:5432/ms3_operativo
DATABASE_URL=sqlite:///./ms3_local.db

# JWT - clave PUBLICA de MS1 (RS256). Copia ms1-empresarial/keys/public.pem aqui.
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256

# CORS - origenes del frontend (separados por coma)
CORS_ORIGINS=http://localhost:4200

# --- Chatbot BI (CU-16): genera/exporta informes desde prompts en lenguaje natural ---
# Sin CLAUDE_API_KEY el endpoint /api/ops/bi/chat responde 503. Pega tu key aqui.
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# --- Fases siguientes (placeholders, aun no usados) ---
MS1_URL=http://localhost:3001/graphql
MS2_URL=http://localhost:8080/api/docs
# n8n: un webhook por evento. Vacio = ese aviso no se dispara (best-effort, no rompe).
N8N_WEBHOOK_URL=
N8N_BIENVENIDA_URL=
N8N_INCIDENTE_URL=

# --- Blockchain (CU-14) - Sepolia. Vacio = solo registro local del hash ---
WEB3_PROVIDER=https://sepolia.infura.io/v3/<TU_INFURA_KEY>
WALLET_PRIVATE_KEY=<clave privada de una wallet DEDICADA, solo testnet>
CONTRACT_ADDRESS=<address del contrato CourierTrace tras deploy>
CHAIN_ID=11155111
